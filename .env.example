# Required
ZENDESK_SUBDOMAIN=mycompany

# OAuth (HTTP transport) — optional, defaults to ${ZENDESK_SUBDOMAIN}_zendesk
# ZENDESK_OAUTH_CLIENT_ID=your_client_id

# API token (stdio transport)
# ZENDESK_EMAIL=agent@company.com
# ZENDESK_API_TOKEN=your_api_token

# Optional
# PORT=0
# TRANSPORT=auto
# LOG_LEVEL=info
